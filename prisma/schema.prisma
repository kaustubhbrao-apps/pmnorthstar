generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  name           String
  // Nullable — Google-only accounts have no password.
  passwordHash   String?         @map("password_hash")
  // Set when a user signs in via Google OAuth. Unique so we can
  // look up users by their Google identity. Nullable for legacy /
  // email-only accounts.
  googleId       String?         @unique @map("google_id")
  // Avatar URL from Google profile, harmless to store.
  image          String?
  // Set on every successful login. Query in Supabase SQL Editor:
  //   SELECT email, name, last_login_at FROM users ORDER BY last_login_at DESC NULLS LAST;
  lastLoginAt    DateTime?       @map("last_login_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  likedResources      LikedResource[]
  savedResources      SavedResource[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  drillAttempts       DrillAttempt[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

model SavedResource {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  resourceId String   @map("resource_id")
  title      String
  author     String
  category   String
  link       String
  savedAt    DateTime @default(now()) @map("saved_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([userId])
  @@map("saved_resources")
}

model LikedResource {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  resourceId String   @map("resource_id")
  title      String
  author     String
  category   String
  link       String
  likedAt    DateTime @default(now()) @map("liked_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([userId])
  @@map("liked_resources")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

// One row per CheckIt audit run. No relation to User on purpose: most
// CheckIt visitors are anonymous, and tracking who ran what would be
// privacy-hostile. Query via Supabase SQL Editor for usage analytics:
//   SELECT COUNT(*) FROM checkit_audits;
//   SELECT host, COUNT(*) FROM checkit_audits GROUP BY host ORDER BY 2 DESC LIMIT 20;
//   SELECT band, COUNT(*) FROM checkit_audits GROUP BY band;
model CheckitAudit {
  id        String   @id @default(uuid())
  host      String
  score     Int
  band      String
  cached    Boolean  @default(false)
  fetchedAt DateTime @default(now()) @map("fetched_at")

  @@index([fetchedAt])
  @@index([host])
  @@map("checkit_audits")
}

// One row per SimulateIt drill completion by a logged-in user.
// Anonymous plays are tracked in localStorage only — those don't
// persist here. Per-dimension scores stored so the user profile
// page can render rollups without re-parsing pathTaken on every
// request. pathTaken kept as JSON for completeness + future
// features (replay, dimensional drill-down).
model DrillAttempt {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  drillSlug     String   @map("drill_slug")
  score         Int
  maxPossible   Int      @map("max_possible")
  productScore  Int      @default(0) @map("product_score")
  productMax    Int      @default(0) @map("product_max")
  businessScore Int      @default(0) @map("business_score")
  businessMax   Int      @default(0) @map("business_max")
  founderScore  Int      @default(0) @map("founder_score")
  founderMax    Int      @default(0) @map("founder_max")
  pathTaken     Json     @map("path_taken")
  attemptedAt   DateTime @default(now()) @map("attempted_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, attemptedAt])
  @@index([drillSlug])
  @@map("drill_attempts")
}
