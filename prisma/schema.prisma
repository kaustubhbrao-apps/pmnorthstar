generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  name                String
  passwordHash        String?              @map("password_hash")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  lastLoginAt         DateTime?            @map("last_login_at")
  googleId            String?              @unique @map("google_id")
  image               String?
  leaguePoints        Int                  @default(0) @map("league_points")
  likedResources      LikedResource[]
  passwordResetTokens PasswordResetToken[]
  savedResources      SavedResource[]
  sessions            Session[]
  drillAttempts       DrillAttempt[]
  leagueReferrals     LeagueReferral[]     @relation("Referrer")
  leagueReferred      LeagueReferral[]     @relation("Referred")

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

model SavedResource {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  resourceId String   @map("resource_id")
  title      String
  author     String
  category   String
  link       String
  savedAt    DateTime @default(now()) @map("saved_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([userId])
  @@map("saved_resources")
}

model LikedResource {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  resourceId String   @map("resource_id")
  title      String
  author     String
  category   String
  link       String
  likedAt    DateTime @default(now()) @map("liked_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([userId])
  @@map("liked_resources")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

model CheckitAudit {
  id        String   @id @default(uuid())
  host      String
  score     Int
  band      String
  cached    Boolean  @default(false)
  fetchedAt DateTime @default(now()) @map("fetched_at")

  @@index([fetchedAt])
  @@index([host])
  @@map("checkit_audits")
}

model DrillAttempt {
  id                 String   @id @default(uuid())
  userId             String   @map("user_id")
  drillSlug          String   @map("drill_slug")
  score              Int
  maxPossible        Int      @map("max_possible")
  productScore       Int      @default(0) @map("product_score")
  productMax         Int      @default(0) @map("product_max")
  businessScore      Int      @default(0) @map("business_score")
  businessMax        Int      @default(0) @map("business_max")
  founderScore       Int      @default(0) @map("founder_score")
  founderMax         Int      @default(0) @map("founder_max")
  pathTaken          Json     @map("path_taken")
  attemptedAt        DateTime @default(now()) @map("attempted_at")
  isFirstAttempt     Boolean  @default(false) @map("is_first_attempt")
  leaguePointsEarned Int      @default(0) @map("league_points_earned")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, attemptedAt])
  @@index([drillSlug])
  @@map("drill_attempts")
}

model LeagueReferral {
  id         String   @id @default(uuid())
  referrerId String   @map("referrer_id")
  referredId String   @map("referred_id")
  drillSlug  String   @map("drill_slug")
  points     Int      @default(3)
  createdAt  DateTime @default(now()) @map("created_at")

  referrer   User     @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred   User     @relation("Referred", fields: [referredId], references: [id], onDelete: Cascade)

  @@unique([referrerId, drillSlug])
  @@index([referrerId])
  @@map("league_referrals")
}

model SimulateAttempt {
  id          String   @id @default(uuid())
  drillSlug   String   @map("drill_slug")
  score       Int
  maxPossible Int      @map("max_possible")
  completedAt DateTime @default(now()) @map("completed_at")

  @@index([completedAt])
  @@index([drillSlug])
  @@map("simulate_attempts")
}
