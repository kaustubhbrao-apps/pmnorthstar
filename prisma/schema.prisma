generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  name           String
  passwordHash   String          @map("password_hash")
  // Set to true for the editor account that can access /admin and
  // write to content tables. All write endpoints check this column.
  isAdmin        Boolean         @default(false) @map("is_admin")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  likedResources      LikedResource[]
  savedResources      SavedResource[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

model SavedResource {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  resourceId String   @map("resource_id")
  title      String
  author     String
  category   String
  link       String
  savedAt    DateTime @default(now()) @map("saved_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([userId])
  @@map("saved_resources")
}

model LikedResource {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  resourceId String   @map("resource_id")
  title      String
  author     String
  category   String
  link       String
  likedAt    DateTime @default(now()) @map("liked_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([userId])
  @@map("liked_resources")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

// ─── CONTENT MODELS ────────────────────────────────────────────────────
// All editable from /admin. IDs are the existing string IDs ("cs-1",
// "pm-1", etc.) so URL slugs and cross-references in the seed data
// continue to resolve. publishedAt = null means draft (only visible in
// admin). Nested/array fields use Json columns to preserve current
// shapes without splitting into normalized tables.

model CaseStudy {
  id          String    @id // legacy IDs (cs-1, cs-2, ...) preserved for URL stability
  slug        String    @unique
  title       String
  company     String
  category    String    // "Product" | "Growth" | "Strategy" | "Design" | "Failure"
  description String
  outcome     String
  year        Int
  tags        String[]
  content     String    @db.Text
  logo        String
  region      String?   // "India" or null
  faqs        Json?     // [{ question, answer }, ...]
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([slug])
  @@index([category])
  @@map("case_studies")
}

model Book {
  id           String    @id // legacy IDs (pm-1, st-1, mg-1, ...) preserved
  slug         String    @unique
  title        String
  author       String
  category     String    // "Product Management" | "Startups" | "Management"
  thumbnailURL String    @map("thumbnail_url")
  link         String
  amazonUrl    String?   @map("amazon_url")
  description  String
  rating       Float
  pages        Int
  year         Int
  tags         String[]
  featured     Boolean   @default(false)
  summary      Json?     // BookSummary shape — analysis[], keyConcepts[], whoShouldRead, pairsWith[], relatedCaseStudies[]
  publishedAt  DateTime? @map("published_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([slug])
  @@index([category])
  @@map("books")
}

model Playlist {
  id          String    @id // legacy IDs preserved
  title       String
  channel     String
  category    String
  description String
  url         String
  thumbnail   String
  imageUrl    String?   @map("image_url")
  videos      Int?
  level       String?   // "Beginner" | "Intermediate" | "Advanced"
  tags        String[]
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([category])
  @@map("playlists")
}

model Topic {
  slug             String    @id
  title            String
  eyebrow          String
  intro            String
  metaTitle        String    @map("meta_title")
  metaDescription  String    @map("meta_description")
  keywords         String[]
  accentColor      String    @map("accent_color")
  caseStudyIds     String[]  @map("case_study_ids")
  publishedAt      DateTime? @map("published_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@map("topics")
}

model Comparison {
  slug             String    @id
  companyA         String    @map("company_a") // case study ID
  companyB         String    @map("company_b") // case study ID
  title            String
  eyebrow          String
  intro            String
  verdict          String
  metaTitle        String    @map("meta_title")
  metaDescription  String    @map("meta_description")
  keywords         String[]
  accentColor      String    @map("accent_color")
  rows             Json      // [{ label, a, b }, ...]
  publishedAt      DateTime? @map("published_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@map("comparisons")
}
